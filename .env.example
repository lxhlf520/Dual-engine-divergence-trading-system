# OKX API Credentials (NEVER commit this file)
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_secret_here
OKX_API_PASSWORD=your_passphrase_here

# Log level
LOG_LEVEL=INFO

# Proxy for domestic servers
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Telegram notifications (recommended)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DINGTALK_WEBHOOK=
